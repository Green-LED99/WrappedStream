# ── Required ──────────────────────────────────────────────────
# Discord user token (NOT a bot token).
DISCORD_TOKEN=

# ── Optional ──────────────────────────────────────────────────
# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Paths to external binaries (defaults work if they're on $PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
YTDLP_PATH=yt-dlp

# ── Performance tuning ────────────────────────────────────────
# Video encoder: auto | h264_nvmpi | h264_v4l2m2m | libx264 (default: auto)
# auto detects the best available encoder at startup.
VIDEO_ENCODER=auto

# Subtitle burn-in: auto | never (default: auto)
# Set to "never" on low-power devices to avoid forced transcode.
SUBTITLE_BURN_IN=auto

# Performance profile: default | low-power (default: default)
# low-power = 24fps, 1800kbps, superfast preset (for ARM SBCs / Jetson Nano).
PERFORMANCE_PROFILE=default

# ── play-search only ─────────────────────────────────────────
# Torrentio addon manifest URL with Real-Debrid credentials baked in.
# Get yours at: https://torrentio.strem.fun/
# Example: https://torrentio.strem.fun/realdebrid=APIKEY/manifest.json
STREMIO_ADDON_URL=
