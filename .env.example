# ── Required ──────────────────────────────────────────────────────────
# Discord user token (NOT a bot token).
# See README for instructions on finding your token.
DISCORD_TOKEN=

# ── Logging ───────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info

# ── External binaries ────────────────────────────────────────────────
# Paths to FFmpeg/ffprobe/yt-dlp. Defaults work if they're on $PATH.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
YTDLP_PATH=yt-dlp

# ── Transcode settings ──────────────────────────────────────────────
# Video encoder selection.
#   auto       — auto-detect HW encoder (h264_nvmpi → h264_v4l2m2m → libx264)
#   h264_nvmpi — NVIDIA Jetson hardware encoder
#   h264_v4l2m2m — V4L2 hardware encoder (Raspberry Pi)
#   libx264    — software encoder (always available)
VIDEO_ENCODER=auto

# Preferred language for audio and subtitle track selection.
# Uses ISO 639-2/B codes (eng, fre, jpn, spa, ger, etc.).
# Two-letter ISO 639-1 codes (en, fr, ja) are also accepted.
# When no matching track is found, falls back to the first available.
LANGUAGE=eng

# Subtitle burn-in behavior.
#   auto  — burn subtitles matching LANGUAGE into video if detected
#   never — never burn in subtitles
SUBTITLE_BURN_IN=auto

# Performance profile for transcoding.
#   default   — 720p 30fps, 2500kbps target, 128kbps audio
#   low-power — 720p 24fps, 1800kbps target, 96kbps audio, x264 "superfast"
# Recommended: use "low-power" on Jetson Nano / Raspberry Pi.
PERFORMANCE_PROFILE=default

# ── play-search (Stremio + Real-Debrid) ──────────────────────────────
# Torrentio addon manifest URL with Real-Debrid credentials baked in.
# Get yours at: https://torrentio.strem.fun/
# Example: https://torrentio.strem.fun/realdebrid=APIKEY/manifest.json
STREMIO_ADDON_URL=
