# Discord user account token (required)
DISCORD_TOKEN=

# Target guild snowflake ID (required)
DISCORD_GUILD_ID=

# Target voice channel snowflake ID (required)
DISCORD_CHANNEL_ID=

# Direct .mp4 or .mkv URL to stream (required)
VIDEO_URL=

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Path to ffmpeg binary (default: ffmpeg)
FFMPEG_PATH=ffmpeg

# Path to ffprobe binary (default: ffprobe)
FFPROBE_PATH=ffprobe
